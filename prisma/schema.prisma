generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// USER
// ==========================================
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?

  // Business info
  businessName  String?
  gstin         String?
  pan           String?
  phone         String?
  address       String?
  city          String?
  state         String?
  pincode       String?
  logoUrl       String?
  signature     String?

  // Settings
  currency      String    @default("INR")
  invoicePrefix String    @default("INV")
  nextInvoiceNo Int       @default(1)
  plan          Plan      @default(FREE)
  planExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  accounts    Account[]
  sessions    Session[]
  clients     Client[]
  invoices    Invoice[]
  expenses    Expense[]
  items       Item[]

  @@map("users")
}

// ==========================================
// NEXTAUTH
// ==========================================
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ==========================================
// CLIENT
// ==========================================
model Client {
  id           String  @id @default(cuid())
  userId       String
  name         String
  email        String?
  phone        String?
  gstin        String?
  pan          String?
  address      String?
  city         String?
  state        String?
  pincode      String?
  country      String  @default("India")
  notes        String?
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@map("clients")
}

// ==========================================
// INVOICE
// ==========================================
model Invoice {
  id            String        @id @default(cuid())
  userId        String
  clientId      String
  invoiceNumber String
  status        InvoiceStatus @default(DRAFT)

  // Dates
  issueDate     DateTime      @default(now())
  dueDate       DateTime
  paidAt        DateTime?

  // Amounts
  subtotal      Float         @default(0)
  discountType  DiscountType  @default(PERCENTAGE)
  discountValue Float         @default(0)
  discountAmount Float        @default(0)

  // GST
  isGst         Boolean       @default(true)
  gstType       GstType       @default(CGST_SGST)
  cgst          Float         @default(0)
  sgst          Float         @default(0)
  igst          Float         @default(0)
  totalTax      Float         @default(0)

  total         Float         @default(0)
  amountPaid    Float         @default(0)
  amountDue     Float         @default(0)

  // Meta
  notes         String?
  terms         String?
  currency      String        @default("INR")
  templateId    String        @default("default")

  // Recurring
  isRecurring   Boolean       @default(false)
  recurringType RecurringType?
  nextDueDate   DateTime?

  // Reminders
  reminderSent  Boolean       @default(false)
  reminderCount Int           @default(0)
  lastReminderAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  client   Client        @relation(fields: [clientId], references: [id])
  items    InvoiceItem[]
  payments Payment[]

  @@unique([userId, invoiceNumber])
  @@map("invoices")
}

// ==========================================
// INVOICE ITEM
// ==========================================
model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  name        String
  description String?
  hsnCode     String?
  quantity    Float   @default(1)
  unit        String  @default("nos")
  rate        Float
  amount      Float
  taxRate     Float   @default(18)
  taxAmount   Float   @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

// ==========================================
// PAYMENT
// ==========================================
model Payment {
  id            String        @id @default(cuid())
  invoiceId     String
  amount        Float
  method        PaymentMethod @default(UPI)
  transactionId String?
  notes         String?
  paidAt        DateTime      @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ==========================================
// EXPENSE
// ==========================================
model Expense {
  id          String          @id @default(cuid())
  userId      String
  title       String
  amount      Float
  category    ExpenseCategory @default(OTHER)
  date        DateTime        @default(now())
  description String?
  receiptUrl  String?
  isDeductible Boolean        @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("expenses")
}

// ==========================================
// SAVED ITEM (for quick add in invoice)
// ==========================================
model Item {
  id          String  @id @default(cuid())
  userId      String
  name        String
  description String?
  hsnCode     String?
  rate        Float
  unit        String  @default("nos")
  taxRate     Float   @default(18)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("items")
}

// ==========================================
// ENUMS
// ==========================================
enum Plan {
  FREE
  PRO
  AGENCY
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum GstType {
  CGST_SGST
  IGST
  NONE
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum RecurringType {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum PaymentMethod {
  UPI
  BANK_TRANSFER
  CASH
  CHEQUE
  CARD
  RAZORPAY
  OTHER
}

enum ExpenseCategory {
  SOFTWARE
  HARDWARE
  TRAVEL
  FOOD
  MARKETING
  OFFICE
  TAX
  OTHER
}
